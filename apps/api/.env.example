# AI Provider Configuration (Development Only)
# In production, users must provide their own API key via the extension settings

# AI Provider (openai, anthropic, google)
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.6-terra

# Alternative: Anthropic/Claude (requires AI_PROVIDER=anthropic)
# OPENAI_API_KEY=sk-ant-your-anthropic-key-here
# OPENAI_MODEL=claude-sonnet-5

# Alternative: Google Gemini (requires AI_PROVIDER=google)  
# OPENAI_API_KEY=your_google_ai_studio_key_here
# OPENAI_MODEL=gemini-3.5-flash

# Note: 
# - These environment variables are only used as fallback during development
# - The extension will use user-provided API keys in production to avoid server costs
# - We use OPENAI_API_KEY for all providers since they're OpenAI-compatible

# Environment
NODE_ENV=development

# Extension Security / CORS Configuration
# In DEVELOPMENT: All origins are allowed (browser localhost, API tools like Yaak/Postman, extensions)
# In PRODUCTION: Only specific extension IDs are allowed

# Comma-separated list of allowed extension IDs for production (without chrome-extension:// prefix)
# Example: ALLOWED_EXTENSION_IDS=abcdefghijklmnop,qrstuvwxyzabcdef
# How to find your extension ID:
# 1. Go to chrome://extensions/
# 2. Enable "Developer mode" (top right)
# 3. Find your extension and copy the ID
ALLOWED_EXTENSION_IDS=

# Semantic Scholar API Key (https://www.semanticscholar.org/product/api#api-key-form)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# Crossref API Configuration
# Email for Crossref "polite pool" - provides better API performance
CROSSREF_MAILTO=your-email@domain.com

# OpenAlex API Configuration
# Email for OpenAlex "polite pool" - provides better API performance and rate limits
OPENALEX_MAILTO=your-email@domain.com

# Europe PMC API Configuration
# Email for Europe PMC - provides better API performance and support
EUROPEPMC_EMAIL=your-email@domain.com

# Server Port
PORT=8000

# mkdir -p .keystore
# (chmod 700 ist auf macOS/Linux ok; auf Windows ignorierbar)
# chmod 700 .keystore 2>/dev/null || true
MASTER_KEY=a-very-long-and-random-master-key
KEY_DERIVATION_SALT=a-very-long-and-random-salt
KEYSTORE_DIR=.keystore

ANYSTYLE_SERVER_URL=http://localhost:4567

# Loki logging endpoint
# Set this to enable direct pino→Loki transport (works in both dev and Docker)
# Default Loki URL for local development:
# LOKI_URL=http://localhost:3100
# Default Loki URL for Docker deployment:
# LOKI_URL=http://loki:3100

# OpenTelemetry
# OTLP endpoint for trace export (local dev)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTLP endpoint for trace export (Docker)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=source-taster-api

