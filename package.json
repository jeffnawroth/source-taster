{
  "name": "source-taster",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm run -r --parallel --aggregate-output dev",
    "build": "pnpm run -r build",
    "build:api": "pnpm --filter @source-taster/api build",
    "build:extension": "pnpm --filter @source-taster/extension build",
    "build:types": "pnpm --filter @source-taster/types build",
    "test": "pnpm run -r --parallel test",
    "lint": "pnpm run -r --parallel lint",
    "deploy": "pnpm build && pnpm run -r deploy",
    "preinstall": "simple-git-hooks",
    "evaluation": "node evaluation/run-evaluation.js",
    "evaluation:goldset": "node evaluation/build-goldset.js",
    "evaluation:fetch-works": "node evaluation/fetch-openalex-works.js",
    "evaluation:generate-dataset": "node evaluation/generate-openalex-dataset.js",
    "evaluation:export-crossref": "node evaluation/export-crossref-raw.js",
    "evaluation:run-live": "node evaluation/run-live-pipeline.js",
    "evaluation:prepare-input": "node evaluation/build-live-input.js"
  },
  "devDependencies": {
    "@citation-js/plugin-csl": "^0.7.18",
    "citation-js": "^0.7.20",
    "eslint": "^9.36.0",
    "lint-staged": "^16.2.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
